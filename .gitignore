# Dependencies & build output — the CI installs from package-lock and runs the build.
node_modules/
public/
.quartz-cache/
*.tsbuildinfo

# Full library catalog — a local intermediate for library-images.mjs, regenerated
# by `node image-index.mjs`. Kept out of git: it's large and lists the entire
# private teaching collection (the site only needs the downsampled outputs).
image-library.json

# NOTE: content/ IS committed on purpose. The build host (Vercel / Cloudflare) has no
# access to the source vault, so it builds from this checked-in snapshot. Regenerate it
# locally with `node sync.mjs` and commit the result whenever the vault changes.

# Secrets — SITE_PASSWORD lives in the environment (Vercel) and a local .env, never in git.
.env
.env.*

# OS / editor
.DS_Store
Thumbs.db
*.swp

# Cloud-sync conflict copies — this directory sits under a synced home folder, so the
# sync client periodically drops "content 2", "sync 2.mjs" etc. Never commit them.
* [0-9]
* [0-9].*
*conflicted copy*
.vercel
